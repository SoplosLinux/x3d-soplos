From: Sergi Perich <info@soploslinux.com>
Date: 2026-07-17
Subject: [PATCH] sched/x86: AMD X3D VCache scheduler preference for Ryzen X3D

Detect asymmetric L3 cache topology in dual-CCD AMD Ryzen X3D processors
(7950X3D, 9950X3D) and bias task wake-up towards the VCache CCD.

On dual-CCD X3D processors one CCD carries 3D VCache stacking, giving it
roughly 3x more L3 than the other CCD (96 MB vs 32 MB on the 9950X3D).
Gaming and latency-sensitive workloads benefit from running on the VCache
CCD because the larger effective cache reduces cache misses.

Detection happens via a late_initcall after all CPUs are online:
  - Read per-CPU L3 size from the cacheinfo subsystem.
  - If max_l3 > 2 * min_l3 the topology is asymmetric.
  - Build amd_x3d_vcache_mask (larger-L3 CPUs) and amd_x3d_other_mask.
  - Enable the static key so the fast path has zero cost on symmetric
    and non-X3D systems.

Scheduling: in select_task_rq_fair(), after select_idle_sibling() returns,
redirect to an idle VCache CPU when:
  1. The selected CPU is not already on the VCache CCD.
  2. The VCache CCD carries no more proportional load than the other CCD.
  3. An idle VCache CPU is available within the task's allowed cpumask.

Load comparison uses atomic counters (amd_x3d_vcache_running,
amd_x3d_other_running) updated in enqueue_task_fair/dequeue_task_fair.
The hot path in select_task_rq_fair does two atomic_read() calls -- O(1)
regardless of CPU count.

Only activates on AMD family 0x19+ (Zen 3 and later).
Single-CCD X3D (5800X3D, 7800X3D, 9800X3D): symmetric topology,
feature stays disabled.

Soplos Linux patch -- not for upstream submission.
Applies to Linux 7.0.x.

Signed-off-by: Sergi Perich <info@soploslinux.com>
---
 arch/x86/include/asm/topology.h      | 18 +++++++
 arch/x86/kernel/cpu/Makefile         |  1 +
 arch/x86/kernel/cpu/amd_x3d_sched.c | 91 +++++++++++++++++++++++++++
 kernel/sched/fair.c                  | 37 +++++++++++
 4 files changed, 147 insertions(+)
 create mode 100644 arch/x86/kernel/cpu/amd_x3d_sched.c

--- a/arch/x86/include/asm/topology.h
+++ b/arch/x86/include/asm/topology.h
@@ -334,3 +334,18 @@ extern void arch_scale_freq_tick(void);
 extern int arch_sched_node_distance(int from, int to);

+#ifdef CONFIG_CPU_SUP_AMD
+#include <linux/atomic.h>
+#include <linux/cpumask.h>
+#include <linux/jump_label.h>
+
+/* AMD X3D VCache scheduler preference -- see arch/x86/kernel/cpu/amd_x3d_sched.c */
+DECLARE_STATIC_KEY_FALSE(amd_x3d_vcache_active);
+extern cpumask_t amd_x3d_vcache_mask;
+extern cpumask_t amd_x3d_other_mask;
+extern unsigned int amd_x3d_vcache_nr;
+extern unsigned int amd_x3d_other_nr;
+extern atomic_t amd_x3d_vcache_running;
+extern atomic_t amd_x3d_other_running;
+#endif /* CONFIG_CPU_SUP_AMD */
+
 #endif /* _ASM_X86_TOPOLOGY_H */
--- a/arch/x86/kernel/cpu/Makefile
+++ b/arch/x86/kernel/cpu/Makefile
@@ -39,2 +39,3 @@ endif
 endif
 obj-$(CONFIG_CPU_SUP_AMD)		+= amd.o
+obj-$(CONFIG_CPU_SUP_AMD)		+= amd_x3d_sched.o
--- /dev/null
+++ b/arch/x86/kernel/cpu/amd_x3d_sched.c
@@ -0,0 +1,91 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * AMD X3D VCache scheduler preference
+ *
+ * Detects dual-CCD Ryzen X3D processors (7950X3D, 9950X3D) with asymmetric
+ * L3 cache topology and marks VCache CCD cores for preferential scheduling.
+ *
+ * Soplos Linux -- not for upstream submission.
+ */
+
+#define pr_fmt(fmt) "amd_x3d_sched: " fmt
+
+#include <linux/atomic.h>
+#include <linux/cacheinfo.h>
+#include <linux/cpu.h>
+#include <linux/cpumask.h>
+#include <linux/init.h>
+#include <linux/jump_label.h>
+#include <linux/limits.h>
+#include <linux/printk.h>
+#include <asm/processor.h>
+#include <asm/topology.h>
+
+DEFINE_STATIC_KEY_FALSE(amd_x3d_vcache_active);
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_active);
+
+cpumask_t amd_x3d_vcache_mask;
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_mask);
+
+cpumask_t amd_x3d_other_mask;
+EXPORT_SYMBOL_GPL(amd_x3d_other_mask);
+
+unsigned int amd_x3d_vcache_nr;
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_nr);
+
+unsigned int amd_x3d_other_nr;
+EXPORT_SYMBOL_GPL(amd_x3d_other_nr);
+
+atomic_t amd_x3d_vcache_running = ATOMIC_INIT(0);
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_running);
+
+atomic_t amd_x3d_other_running = ATOMIC_INIT(0);
+EXPORT_SYMBOL_GPL(amd_x3d_other_running);
+
+static unsigned int get_cpu_l3_size(unsigned int cpu)
+{
+	struct cpu_cacheinfo *ci;
+	unsigned int i;
+
+	ci = get_cpu_cacheinfo(cpu);
+	if (!ci || !ci->info_list)
+		return 0;
+
+	for (i = 0; i < ci->num_leaves; i++) {
+		struct cacheinfo *leaf = &ci->info_list[i];
+
+		if (leaf->level == 3 && leaf->type == CACHE_TYPE_UNIFIED)
+			return leaf->size;
+	}
+	return 0;
+}
+
+static int __init amd_x3d_vcache_init(void)
+{
+	unsigned int cpu, l3;
+	unsigned int max_l3 = 0, min_l3 = UINT_MAX;
+
+	/* Only AMD Zen 3 (family 0x19) and later support 3D VCache */
+	if (boot_cpu_data.x86_vendor != X86_VENDOR_AMD ||
+	    boot_cpu_data.x86 < 0x19)
+		return 0;
+
+	for_each_online_cpu(cpu) {
+		l3 = get_cpu_l3_size(cpu);
+		if (!l3)
+			continue;
+		if (l3 > max_l3)
+			max_l3 = l3;
+		if (l3 < min_l3)
+			min_l3 = l3;
+	}
+
+	/*
+	 * Asymmetric L3 signature: VCache CCD has ~3x more L3 than the
+	 * standard CCD. Require max_l3 > 2*min_l3 to avoid false positives
+	 * on symmetric multi-CCD systems. Single-CCD X3D (5800X3D, 7800X3D,
+	 * 9800X3D): min_l3 == max_l3 so the feature stays disabled.
+	 */
+	if (!max_l3 || min_l3 == UINT_MAX || max_l3 <= 2 * min_l3)
+		return 0;
+
+	cpumask_clear(&amd_x3d_vcache_mask);
+	cpumask_clear(&amd_x3d_other_mask);
+
+	for_each_online_cpu(cpu) {
+		l3 = get_cpu_l3_size(cpu);
+		if (!l3)
+			continue;
+		if (l3 == max_l3)
+			cpumask_set_cpu(cpu, &amd_x3d_vcache_mask);
+		else
+			cpumask_set_cpu(cpu, &amd_x3d_other_mask);
+	}
+
+	amd_x3d_vcache_nr = cpumask_weight(&amd_x3d_vcache_mask);
+	amd_x3d_other_nr  = cpumask_weight(&amd_x3d_other_mask);
+
+	static_branch_enable(&amd_x3d_vcache_active);
+
+	pr_info("VCache CCD: %u cores %u KB L3 (cpus: %*pbl); other CCD: %u cores\n",
+		amd_x3d_vcache_nr, max_l3 / 1024,
+		cpumask_pr_args(&amd_x3d_vcache_mask),
+		amd_x3d_other_nr);
+
+	return 0;
+}
+late_initcall(amd_x3d_vcache_init);
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -7047,4 +7047,12 @@ enqueue_task_fair(struct rq *rq, struct task_struct *p, int flags)
 	assert_list_leaf_cfs_rq(rq);

+#ifdef CONFIG_CPU_SUP_AMD
+	if (static_branch_unlikely(&amd_x3d_vcache_active)) {
+		if (cpumask_test_cpu(cpu_of(rq), &amd_x3d_vcache_mask))
+			atomic_inc(&amd_x3d_vcache_running);
+		else
+			atomic_inc(&amd_x3d_other_running);
+	}
+#endif /* CONFIG_CPU_SUP_AMD */
 	hrtick_update(rq);
 }
@@ -7186,7 +7194,15 @@ static bool dequeue_task_fair(struct rq *rq, struct task_struct *p, int flags)
 	/*
 	 * Must not reference @p after dequeue_entities(DEQUEUE_DELAYED).
 	 */

+#ifdef CONFIG_CPU_SUP_AMD
+	if (static_branch_unlikely(&amd_x3d_vcache_active)) {
+		if (cpumask_test_cpu(cpu_of(rq), &amd_x3d_vcache_mask))
+			atomic_dec(&amd_x3d_vcache_running);
+		else
+			atomic_dec(&amd_x3d_other_running);
+	}
+#endif /* CONFIG_CPU_SUP_AMD */
 	hrtick_update(rq);
 	return true;
 }
@@ -8635,5 +8651,24 @@ select_task_rq_fair(struct task_struct *p, int prev_cpu, int wake_flags)
 	} else if (wake_flags & WF_TTWU) { /* XXX always ? */
 		/* Fast path */
 		new_cpu = select_idle_sibling(p, prev_cpu, new_cpu);
+#ifdef CONFIG_CPU_SUP_AMD
+		if (static_branch_unlikely(&amd_x3d_vcache_active) &&
+		    !cpumask_test_cpu(new_cpu, &amd_x3d_vcache_mask)) {
+			int vcache_run = atomic_read(&amd_x3d_vcache_running);
+			int other_run = atomic_read(&amd_x3d_other_running);
+			int v;
+
+			if (vcache_run * (int)amd_x3d_other_nr <=
+			    other_run * (int)amd_x3d_vcache_nr) {
+				for_each_cpu_and(v, &amd_x3d_vcache_mask,
+						 p->cpus_ptr) {
+					if (available_idle_cpu(v)) {
+						new_cpu = v;
+						break;
+					}
+				}
+			}
+		}
+#endif /* CONFIG_CPU_SUP_AMD */
 	}
 	rcu_read_unlock();
