index aabbcc..ddeeff 100644
--- a/arch/x86/include/asm/topology.h
+++ b/arch/x86/include/asm/topology.h
@@ -1,5 +1,5 @@
-/* SPDX-License-Identifier: GPL-2.0 */
-#ifndef _ASM_X86_TOPOLOGY_H
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef _ASM_X86_TOPOLOGY_H
 #define _ASM_X86_TOPOLOGY_H

 /*
@@ -179,5 +179,14 @@ static inline void arch_fix_phys_package_id(int num, u32 slot) { }

 #include <asm-generic/topology.h>

+#ifdef CONFIG_CPU_SUP_AMD
+#include <linux/cpumask.h>
+#include <linux/jump_label.h>
+
+/* AMD X3D VCache scheduler preference — see arch/x86/kernel/cpu/amd_x3d_sched.c */
+DECLARE_STATIC_KEY_FALSE(amd_x3d_vcache_active);
+extern cpumask_t amd_x3d_vcache_mask;
+extern unsigned int amd_x3d_vcache_nr;  /* VCache CCD CPU count — stable post-boot */
+extern unsigned int amd_x3d_other_nr;   /* non-VCache CPU count — stable post-boot */
+#endif /* CONFIG_CPU_SUP_AMD */
+
 #endif /* _ASM_X86_TOPOLOGY_H */
