 obj-$(CONFIG_CPU_SUP_HYGON)		+= hygon.o
diff --git a/arch/x86/kernel/cpu/amd_x3d_sched.c b/arch/x86/kernel/cpu/amd_x3d_sched.c
new file mode 100644
index 000000000000..aabbccddee
--- /dev/null
+++ b/arch/x86/kernel/cpu/amd_x3d_sched.c
@@ -0,0 +1,90 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * AMD X3D VCache scheduler preference
+ *
+ * Detects dual-CCD Ryzen X3D processors (7950X3D, 9950X3D) with asymmetric
+ * L3 cache topology and marks VCache CCD cores for preferential scheduling.
+ *
+ * Soplos Linux — not for upstream submission.
+ */
+
+#define pr_fmt(fmt) "amd_x3d_sched: " fmt
+
+#include <linux/cacheinfo.h>
+#include <linux/cpu.h>
+#include <linux/cpumask.h>
+#include <linux/init.h>
+#include <linux/jump_label.h>
+#include <linux/limits.h>
+#include <linux/printk.h>
+#include <asm/processor.h>
+#include <asm/topology.h>
+
+DEFINE_STATIC_KEY_FALSE(amd_x3d_vcache_active);
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_active);
+
+cpumask_t amd_x3d_vcache_mask;
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_mask);
+
+/* Cached post-boot counts — not updated on hotplug (desktop use case) */
+unsigned int amd_x3d_vcache_nr;
+EXPORT_SYMBOL_GPL(amd_x3d_vcache_nr);
+unsigned int amd_x3d_other_nr;
+EXPORT_SYMBOL_GPL(amd_x3d_other_nr);
+
+static unsigned int get_cpu_l3_size(unsigned int cpu)
+{
+	struct cpu_cacheinfo *ci;
+	unsigned int i;
+
+	ci = get_cpu_cacheinfo(cpu);
+	if (!ci || !ci->info_list)
+		return 0;
+
+	for (i = 0; i < ci->num_leaves; i++) {
+		struct cacheinfo *leaf = &ci->info_list[i];
+
+		if (leaf->level == 3 && leaf->type == CACHE_TYPE_UNIFIED)
+			return leaf->size;
+	}
+	return 0;
+}
+
+static int __init amd_x3d_vcache_init(void)
+{
+	unsigned int cpu, l3;
+	unsigned int max_l3 = 0, min_l3 = UINT_MAX;
+
+	/* Only AMD Zen 3 (family 0x19) and later support 3D VCache */
+	if (boot_cpu_data.x86_vendor != X86_VENDOR_AMD ||
+	    boot_cpu_data.x86 < 0x19)
+		return 0;
+
+	/* Scan all online CPUs to find the L3 size range */
+	for_each_online_cpu(cpu) {
+		l3 = get_cpu_l3_size(cpu);
+		if (!l3)
+			continue;
+		if (l3 > max_l3)
+			max_l3 = l3;
+		if (l3 < min_l3)
+			min_l3 = l3;
+	}
+
+	/*
+	 * Asymmetric L3 signature: the VCache CCD has ~3x more L3 than the
+	 * standard CCD (e.g. 98304 KB vs 32768 KB on the 9950X3D).
+	 * Require max_l3 > 2 * min_l3 to avoid false positives on symmetric
+	 * multi-CCD systems where sizes may differ slightly due to binning.
+	 * Single-CCD X3D (5800X3D, 7800X3D, 9800X3D): all CPUs share the
+	 * same L3 size, so min_l3 == max_l3 and the feature stays disabled.
+	 */
+	if (!max_l3 || min_l3 == UINT_MAX || max_l3 <= 2 * min_l3)
+		return 0;
+
+	cpumask_clear(&amd_x3d_vcache_mask);
+	for_each_online_cpu(cpu) {
+		l3 = get_cpu_l3_size(cpu);
+		if (l3 == max_l3)
+			cpumask_set_cpu(cpu, &amd_x3d_vcache_mask);
+	}
+
+	amd_x3d_vcache_nr = cpumask_weight(&amd_x3d_vcache_mask);
+	amd_x3d_other_nr  = num_online_cpus() - amd_x3d_vcache_nr;
+
+	static_branch_enable(&amd_x3d_vcache_active);
+
+	pr_info("VCache CCD detected: %u cores with %u KB L3 (cpus: %*pbl)\n",
+		cpumask_weight(&amd_x3d_vcache_mask),
+		max_l3 / 1024,
+		cpumask_pr_args(&amd_x3d_vcache_mask));
+
+	return 0;
+}
+late_initcall(amd_x3d_vcache_init);
diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index aabbcc..ddeeff 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -6,6 +6,10 @@
  *  Copyright (C) 2007 Red Hat, Inc., Ingo Molnar <mingo@redhat.com>
  */
 #include "sched.h"
+
+#ifdef CONFIG_CPU_SUP_AMD
+#include <asm/topology.h>
+#endif
+
 #include "pelt.h"
 #include "stats.h"

@@ -7060,6 +7064,22 @@ select_task_rq_fair(struct task_struct *p, int prev_cpu, int wake_flags)

 	new_cpu = select_idle_sibling(p, prev_cpu, new_cpu);

+#ifdef CONFIG_CPU_SUP_AMD
+	/*
+	 * AMD X3D VCache preference: if the selected CPU is not on the VCache
+	 * CCD and an idle VCache CPU is available within the task's allowed
+	 * cpumask, redirect there for better cache locality on gaming workloads.
+	 * The static_branch has zero cost when the feature is inactive.
+	 *
+	 * Load threshold: only redirect if the VCache CCD is not already
+	 * carrying more average load than the non-VCache CCD. This prevents
+	 * saturating the VCache CCD in mixed workloads while non-VCache CPUs
+	 * sit idle. Cross-multiplication avoids integer division.
+	 */
+	if (static_branch_unlikely(&amd_x3d_vcache_active) &&
+	    !cpumask_test_cpu(new_cpu, &amd_x3d_vcache_mask)) {
+		unsigned int vcache_run = 0, other_run = 0;
+		int v;
+
+		for_each_online_cpu(v) {
+			if (cpumask_test_cpu(v, &amd_x3d_vcache_mask))
+				vcache_run += cpu_rq(v)->nr_running;
+			else
+				other_run += cpu_rq(v)->nr_running;
+		}
+
+		/* vcache_run/amd_x3d_vcache_nr <= other_run/amd_x3d_other_nr
+		 * CPU counts are cached at boot — stable on desktop systems. */
+		if (vcache_run * amd_x3d_other_nr <= other_run * amd_x3d_vcache_nr) {
+			for_each_cpu_and(v, &amd_x3d_vcache_mask, p->cpus_ptr) {
+				if (available_idle_cpu(v)) {
+					new_cpu = v;
+					break;
+				}
+			}
+		}
+	}
+#endif /* CONFIG_CPU_SUP_AMD */
+
 unlock:
 	rcu_read_unlock();
